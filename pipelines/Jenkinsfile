pipeline {
    agent any

    parameters {
        string(name: 'BRANCH', defaultValue: 'main', description: 'Branch to build')
        choice(name: 'ENVIRONMENT', choices: ['dev', 'staging', 'prod'], description: 'Deployment environment')
    }

    environment {
        DOCKER_REGISTRY = 'docker.io'
        APP_NAME = 'devops-chatbot'
        DOCKER_IMAGE = "siddhantpandey/${APP_NAME}"
        VERSION = "${env.BUILD_ID}"
        STUDENT = "Siddhant Pandey | 23FE10CSE00011"
    }

    stages {
        stage('Checkout') {
            steps {
                echo "Building project by ${STUDENT}"
                git branch: "${params.BRANCH}",
                    url: 'https://github.com/siddhantpandey/devops-project-chatbot.git'
            }
        }

        stage('Code Quality') {
            steps {
                script {
                    echo "Running linting and format checks..."
                    sh 'pip install flake8 black --quiet'
                    sh 'flake8 src/main/app/ --max-line-length=120 || true'
                    sh 'black --check src/main/app/ || true'
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'pip install -r src/main/requirements.txt --quiet'
            }
        }

        stage('Unit Tests') {
            steps {
                script {
                    sh 'pytest tests/unit/ -v --cov=src/main/app --cov-report=xml || true'
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'test-results/*.xml'
                }
            }
        }

        stage('Integration Tests') {
            steps {
                script {
                    sh 'pytest tests/integration/ -v || true'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    echo "Building Docker image: ${DOCKER_IMAGE}:${VERSION}"
                    sh """
                        docker build \
                            -t ${DOCKER_IMAGE}:${VERSION} \
                            -t ${DOCKER_IMAGE}:latest \
                            -f infrastructure/docker/Dockerfile .
                    """
                }
            }
        }

        stage('Security Scan') {
            steps {
                script {
                    echo "Scanning Docker image for vulnerabilities..."
                    sh "trivy image --exit-code 0 --severity HIGH,CRITICAL ${DOCKER_IMAGE}:${VERSION} || true"
                }
            }
        }

        stage('Push to Registry') {
            when {
                anyOf {
                    expression { params.ENVIRONMENT == 'staging' }
                    expression { params.ENVIRONMENT == 'prod' }
                }
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh "echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin"
                    sh "docker push ${DOCKER_IMAGE}:${VERSION}"
                    sh "docker push ${DOCKER_IMAGE}:latest"
                }
            }
        }

        stage('Deploy to Staging') {
            when {
                expression { params.ENVIRONMENT == 'staging' }
            }
            steps {
                script {
                    echo "Deploying to staging..."
                    sh "docker-compose -f infrastructure/docker/docker-compose.yml up -d"
                }
            }
        }

        stage('Deploy to Production') {
            when {
                expression { params.ENVIRONMENT == 'prod' }
            }
            steps {
                input message: 'Deploy DevOps Chatbot to production?', ok: 'Deploy Now'
                script {
                    echo "Deploying to Kubernetes production..."
                    sh "kubectl apply -f infrastructure/kubernetes/"
                    sh "kubectl rollout status deployment/devops-chatbot --timeout=120s"
                }
            }
        }
    }

    post {
        success {
            echo "Pipeline succeeded for ${APP_NAME} v${VERSION}"
            emailext(
                subject: "✅ Pipeline Successful: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: "The pipeline completed successfully.\n\nStudent: ${STUDENT}\nBuild: ${env.BUILD_URL}",
                to: '23FE10CSE00011@example.edu'
            )
        }
        failure {
            echo "Pipeline failed for ${APP_NAME} v${VERSION}"
            emailext(
                subject: "❌ Pipeline Failed: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: "The pipeline failed. Please check logs.\n\nBuild URL: ${env.BUILD_URL}",
                to: '23FE10CSE00011@example.edu'
            )
        }
        always {
            sh "docker rmi ${DOCKER_IMAGE}:${VERSION} || true"
        }
    }
}
